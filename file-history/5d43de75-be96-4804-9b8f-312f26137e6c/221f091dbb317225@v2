%--- Slide 9: CPU Index Construction ---
\begin{frame}{City-Level CPU Index Construction}
  \textbf{Data Source}: News articles on climate policy from Chinese newspapers (2007--2023)

  \vspace{0.3cm}

  \textbf{Construction Method} (following Baker et al., 2016):
  \begin{enumerate}
    \item Articles containing climate-related terms AND policy-uncertainty terms
    \item Monthly count per city $\rightarrow$ normalized by total article count
    \item Natural logarithm transformation: $\lncpu_{ct}$
  \end{enumerate}

  \vspace{0.4cm}

  \begin{center}
    \small
    \begin{tabular}{lcc}
      \toprule
      \textbf{Region} & \textbf{Max CPU} & \textbf{Min CPU} \\
      \midrule
      Bayannur, Inner Mongolia & 1.342 (2023) & -- \\
      Xiangfan, Hubei & -- & $-$1.620 (2008) \\
      \bottomrule
    \end{tabular}
  \end{center}

  \vspace{0.3cm}
  \textit{Note: Spatial and temporal heterogeneity reflects variation in economic development, industrial composition, and environmental governance pressures.}
\end{frame}

