%--- Slide 6: Theoretical Mechanism ---
\begin{frame}{Theoretical Mechanism: How CPU Affects Investment}
  Climate policy uncertainty affects corporate investment through \textbf{two primary channels}:

  \vspace{0.4cm}

  \begin{columns}[t]
    \column{0.48\textwidth}
      \begin{block}{Channel 1: Financial Constraints}
        When policy uncertainty is high:
        \begin{itemize}
          \item Creditors increase risk premiums
          \item Banks become more selective in lending
          \item External financing becomes more costly
        \end{itemize}
      \end{block}

    \column{0.48\textwidth}
      \begin{block}{Channel 2: Cash Flow}
        When policy uncertainty is high:
        \begin{itemize}
          \item Future revenue expectations become uncertain
          \item Operating cash flows become volatile
          \item Internal funds for investment decline
        \end{itemize}
      \end{block}
  \end{columns}

  \vspace{0.4cm}

  \textbf{Empirical Prediction}: CPU $\uparrow$ $\Rightarrow$ Invest $\downarrow$
\end{frame}

%--- Slide 7: Hypotheses ---
\begin{frame}{Hypotheses Development}
  \begin{block}{Hypothesis H1}
    \textit{Climate policy uncertainty negatively affects corporate real investment.}
  \end{block}

  \vspace{0.3cm}

  \begin{block}{Hypothesis H2}
    \textit{Climate policy uncertainty tightens financial constraints, reducing corporate real investment.}
  \end{block}

  \vspace{0.3cm}

  \begin{block}{Hypothesis H3}
    \textit{Climate policy uncertainty weakens corporate cash flows, reducing corporate real investment.}
  \end{block}

  \vspace{0.3cm}

  \textit{Note: Additional heterogeneity hypotheses for regions, ownership, industry, and ESG will be examined.}
\end{frame}

