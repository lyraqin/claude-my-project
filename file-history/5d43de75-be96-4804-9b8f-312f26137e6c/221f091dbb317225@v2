%--- Slide 2: Motivation ---
\begin{frame}{Motivation: Why Study Climate Policy Uncertainty?}
  \begin{itemize}
    \item \textbf{Global Context}: Escalating climate change has prompted worldwide policy responses
    \item \textbf{Policy Uncertainty}: Climate policies vary in timing, intensity, and content across regions
    \item \textbf{Corporate Impact}: Firms face increasingly uncertain and dynamic regulatory environments
  \end{itemize}

  \vspace{0.5cm}

  \begin{block}{Key Insight}
    When policy uncertainty is high, firms face a \textit{real options problem}:
    \begin{itemize}
      \item Delay investment to wait for clarity
      \item Adjust capital structure to manage risk
      \item Seek alternative financing channels (e.g., trade credit)
    \end{itemize}
  \end{block}

  \vspace{0.3cm}
  \textit{Question: How does climate policy uncertainty affect corporate real investment decisions?}
\end{frame}

%--- Slide 3: Research Question & Contributions ---
\begin{frame}{Research Question and Contributions}
  \begin{alertblock}{Research Question}
    What is the effect of climate policy uncertainty (CPU) on corporate real investment, and through what channels does this effect operate?
  \end{alertblock}

  \vspace{0.4cm}

  \textbf{Key Contributions:}
  \begin{enumerate}
    \item \textbf{Novel Data}: First study using city-level CPU indices for Chinese firms (2007--2023)
    \item \textbf{Mechanism Identification}: Documents two transmission channels:
      \begin{itemize}
        \item Financial constraints
        \item Cash flow reduction
      \end{itemize}
    \item \textbf{Heterogeneous Effects}: Shows varied impacts across:
      \begin{itemize}
        \item Regional development levels
        \item Ownership type (private vs. SOE)
        \item Industry characteristics (manufacturing, labor-intensive)
      \end{itemize}
    \item \textbf{Supply Chain Evidence}: Identifies trade credit as a mitigation mechanism
  \end{enumerate}
\end{frame}

%--- Slide 4: Literature Context ---
\begin{frame}{Literature Context}
  \textbf{Policy Uncertainty and Investment:}
