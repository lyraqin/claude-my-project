%--- Slide 11: Baseline Model ---
\begin{frame}{Baseline Model Specification}
  \begin{block}{Main Regression Model}
    \begin{equation*}
      \invest_{i,t} = \beta_0 + \beta_1 \lncpu_{c,t-1} + X_{i,t-1}\gamma + \mu_i + \delta_t + \epsilon_{i,t}
    \end{equation*}
  \end{block}

  \vspace{0.3cm}

  \textbf{Notation}:
  \begin{itemize}
    \item $\invest_{i,t}$: Real investment of firm $i$ in year $t$
    \item $\lncpu_{c,t-1}$: Logged CPU in city $c$ (lagged)
    \item $X_{i,t-1}$: Control variables (size, leverage, ROA, etc.)
    \item $\mu_i$: Firm fixed effects
    \item $\delta_t$: Year fixed effects
  \end{itemize}

  \vspace{0.3cm}

  \textbf{Expected Sign}: $\beta_1 < 0$ (higher CPU $\rightarrow$ lower investment)
\end{frame}

%--- Slide 12: Mechanism Model ---
\begin{frame}{Mechanism Analysis Model}
  \begin{block}{Channels Transmission Model}
    \begin{equation*}
      M_{i,t} = \alpha_0 + \alpha_1 \lncpu_{c,t-1} + X_{i,t-1}\theta + \mu_i + \delta_t + \nu_{i,t}
    \end{equation*}
  \end{block}

  \vspace{0.3cm}

  \textbf{Channel Variables ($M_{i,t}$)}:
  \begin{itemize}
    \item \textbf{Cash Flow}: CF1, CF2 (operating cash flow measures)
    \item \textbf{Financial Constraints}:
      \begin{itemize}
        \item SA index (Hadlock \& Pierce, 2010)
        \item WW index (Whited \& Wu, 2006)
      \end{itemize}
  \end{itemize}

  \vspace{0.3cm}

  \textbf{Expected Sign}:
  \begin{itemize}
    \item $\alpha_1 < 0$ for CF: CPU reduces cash flow
    \item $\alpha_1 > 0$ for SA/WW: CPU increases financial constraints
  \end{itemize}
\end{frame}

%--- Slide 13: Identification Strategy ---
\begin{frame}{Identification Strategy}
  Three complementary approaches for causal inference:

  \vspace{0.3cm}

  \begin{enumerate}
    \item \textbf{Instrumental Variables (2SLS)}
      \begin{itemize}
        \item IV: Extreme high temperature days (HTD)
        \item Rationale: Weather shocks $\rightarrow$ policy urgency $\rightarrow$ CPU, but not directly to investment
      \end{itemize}

    \item \textbf{Difference-in-Differences (DID)}
      \begin{itemize}
        \item Treatment: High-CPU firms (top 25\% pre-2016)
        \item Policy shock: 2016 climate policy implementation
        \item Equation: $\invest = \beta + \delta_1 \text{Treat}_i + \delta_2 \text{Time}_t + \delta_3 (\text{Treat} \times \text{Time})_{i,t} + \epsilon$
      \end{itemize}

    \item \textbf{Propensity Score Matching + DID}
      \begin{itemize}
        \item Match treatment and control firms on pre-treatment characteristics
        \item Addresses selection bias, strengthens parallel trends
      \end{itemize}
  \end{enumerate}
\end{frame}

