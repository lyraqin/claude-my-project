%--- Slide 16: Robustness Checks ---
\begin{frame}{Robustness Checks}
  The baseline result holds across multiple specifications:

  \vspace{0.3cm}

  \begin{enumerate}
    \item \textbf{Additional Fixed Effects}
      \begin{itemize}
        \item Industry FE: $\beta = -0.004^{***}$
        \item Province FE: $\beta = -0.005^{***}$
      \end{itemize}

    \item \textbf{Risk Controls}
      \begin{itemize}
        \item Physical Risk (lnCPRI): $\beta = -0.003^{**}$
        \item Economic Policy Uncertainty (FEPU): $\beta = -0.003^{**}$
      \end{itemize}

    \item \textbf{Subsample Analysis}
      \begin{itemize}
        \item Exclude crisis periods (2008--2009, 2020): $\beta = -0.004^{**}$
      \end{itemize}

    \item \textbf{2SLS Results}
      \begin{itemize}
        \item First-stage: HTD $\rightarrow$ CPU (strong, significant)
        \item Second-stage: CPU $\rightarrow$ $-0.003^{*}$ (significant)
      \end{itemize}
  \end{enumerate}
\end{frame}

