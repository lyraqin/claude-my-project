%--- Slide 23: Key Findings Summary ---
\begin{frame}{Key Findings Summary}
  \begin{enumerate}
    \item \textbf{Baseline Finding}
      \begin{itemize}
        \item Climate policy uncertainty significantly reduces corporate real investment
        \item Effect persists across multiple robustness checks
      \end{itemize}

    \item \textbf{Transmission Channels}
      \begin{itemize}
        \item Financial constraints tighten (higher SA/WW indices)
        \item Cash flow weakens (lower CF1/CF2)
      \end{itemize}

    \item \textbf{Heterogeneous Effects}
      \begin{itemize}
        \item Vulnerable: Low-GDP regions, private firms, manufacturing, labor-intensive industries
        \item Resilient: High ESG firms, SOEs with strong government connections
      \end{itemize}

    \item \textbf{Supply Chain Mechanisms}
      \begin{itemize}
        \item Trade credit from upstream suppliers mitigates effects
        \item Lower customer concentration reduces vulnerability
      \end{itemize}
  \end{enumerate}
\end{frame}

